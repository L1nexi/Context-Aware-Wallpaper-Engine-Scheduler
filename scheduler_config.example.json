{
  "wallpaper_engine_path": "C:\\Path\\To\\Your\\wallpaper64.exe",
  "tags": {
    "#dawn": { "fallback": { "#day": 0.7, "#chill": 0.3 } },
    "#sunset": { "fallback": { "#chill": 0.3, "#night": 0.7 } },
    "#spring": { "fallback": { "#day": 0.5, "#chill": 0.5 } },
    "#summer": { "fallback": { "#day": 0.7, "#clear": 0.3 } },
    "#autumn": { "fallback": { "#sunset": 0.6, "#chill": 0.4 } },
    "#winter": { "fallback": { "#night": 0.5, "#chill": 0.5 } },
    "#storm": { "fallback": { "#rain": 1 } },
    "#snow": { "fallback": { "#winter": 0.6, "#rain": 0.6 } },
    "#fog": { "fallback": { "#rain": 0.4, "#chill": 0.4 } },
    "#cloudy": { "fallback": { "#clear": 0.5, "#chill": 0.3 } }
  },
  "playlists": [
    {
      "name": "BRIGHT_FLOW",
      "color": "#F5C518",
      "tags": { "#focus": 1.0, "#day": 0.9, "#dawn": 0.3, "#clear": 0.3 },
      "display": "日光流动"
    },
    {
      "name": "CASUAL_ANIME",
      "color": "#5BB8D4",
      "tags": { "#chill": 1.0, "#day": 0.9, "#clear": 0.3 },
      "display": "次元日常"
    },
    {
      "name": "SUNSET_GLOW",
      "color": "#FF8C00",
      "tags": { "#sunset": 1.0, "#chill": 0.5, "#clear": 0.3 },
      "display": "夕阳余晖"
    },
    {
      "name": "NIGHT_CHILL",
      "color": "#7B68EE",
      "tags": { "#chill": 1.0, "#night": 0.9, "#clear": 0.2 },
      "display": "闲适夜晚"
    },
    {
      "name": "NIGHT_FOCUS",
      "color": "#2E5F8A",
      "tags": { "#focus": 1.0, "#night": 0.9, "#clear": 0.2 },
      "display": "深夜专注"
    },
    {
      "name": "RAINY_MOOD",
      "color": "#4A90D9",
      "tags": {
        "#rain": 1.2,
        "#storm": 0.4,
        "#day": 0.3,
        "#night": 0.3,
        "#chill": 0.3
      },
      "display": "雨落时分"
    },
    {
      "name": "SPRING_BLOOM",
      "color": "#5CBE5C",
      "tags": { "#spring": 1.0, "#day": 0.5, "#clear": 0.3, "#chill": 0.2 },
      "display": "春日绿意"
    },
    {
      "name": "SUMMER_GLOW",
      "color": "#D83820",
      "tags": { "#summer": 1.0, "#day": 0.5, "#clear": 0.4, "#chill": 0.3 },
      "display": "盛夏之感"
    },
    {
      "name": "AUTUMN_DRIFT",
      "color": "#C07830",
      "tags": {
        "#autumn": 1.0,
        "#sunset": 0.5,
        "#day": 0.3,
        "#chill": 0.3,
        "#clear": 0.2
      },
      "display": "秋日私语"
    },
    {
      "name": "WINTER_VIBES",
      "color": "#ADC8E0",
      "tags": {
        "#winter": 1.0,
        "#sunset": 0.7,
        "#snow": 0.5,
        "#chill": 0.3,
        "#clear": 0.3
      },
      "display": "暖冬氛围"
    }
  ],
  "policies": {
    "activity": {
      "enabled": true,
      "weight_scale": 1.2,
      "smoothing_window": 120,
      "process_rules": {
        "Code.exe": "#focus",
        "Obsidian.exe": "#focus",
        "POWERPNT.EXE": "#focus",
        "Acrobat.exe": "#focus",
        "DingTalk.exe": "#focus",
        "Feishu.exe": "#focus",
        "Wemeet.exe": "#focus",
        "steam.exe": "#chill",
        "explorer.exe": "#chill",
        "chrome.exe": "#chill",
        "firefox.exe": "#chill",
        "cloudmusic.exe": "#chill",
        "ui32.exe": "#chill",
        "QQ.exe": "#chill"
      },
      "title_rules": {
        "GitHub": "#focus",
        "Stack Overflow": "#focus",
        "Docs": "#focus",
        "Jupyter": "#focus",
        "YouTube": "#chill",
        "直播": "#chill"
      }
    },
    "season": { "enabled": true, "weight_scale": 0.65 },
    "time": {
      "enabled": true,
      "weight_scale": 0.8,
      "auto": true,
      "day_start_hour": 8,
      "night_start_hour": 20
    },
    "weather": {
      "enabled": true,
      "weight_scale": 1.5,
      "api_key": "YOUR_OPENWEATHERMAP_API_KEY",
      "lat": "0",
      "lon": "0",
      "fetch_interval": 600,
      "request_timeout": 10
    }
  },
  "scheduling": {
    "startup_delay": 15,
    "idle_threshold": 20,
    "switch_cooldown": 150,
    "cycle_cooldown": 900,
    "force_after": 3600,
    "cpu_threshold": 85,
    "cpu_sample_window": 10,
    "pause_on_fullscreen": true
  }
}
